# ─── Required ───────────────────────────────────────────────────────────────
# Generate a random string for programmatic API access (curl, scripts).
# Not needed in the browser when LOCAL_DEV_MODE=true (default).
API_KEY=generate-a-random-string-here

# GitHub Models token — primary LLM for translation and summarization.
GITHUB_TOKEN=

# Google Gemini — fallback when GitHub Models fails or is rate-limited (429).
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Rate limiting — GitHub Models allows ~10 requests/minute per model.
LLM_MIN_REQUEST_INTERVAL=6.5
LLM_MAX_RETRIES=4
LLM_RETRY_BASE_DELAY=10

# ─── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOCAL_DEV_MODE=true
OPENAPI_ENABLED=true
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ─── Pipeline concurrency ───────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=1

# ─── Speech-to-text (faster-whisper) ────────────────────────────────────────
MODEL_SIZE=base
DEVICE=cpu
COMPUTE_TYPE=int8
STT_BEAM_SIZE=5
MAX_CONCURRENT_TRANSCRIPTIONS=1

# ─── Voice activity detection ───────────────────────────────────────────────
SILERO_VAD_DIR=models/silero-vad

# ─── LLM (GitHub Models / Azure inference) ──────────────────────────────────
LLM_API_BASE=https://models.inference.ai.azure.com
LLM_ENDPOINT=https://models.inference.ai.azure.com/chat/completions
LLM_MODEL_NAME=gpt-4o
TRANSLATION_CHUNK_SIZE=15

# ─── Audio / FFmpeg ─────────────────────────────────────────────────────────
FFMPEG_BINARY_PATH=ffmpeg
PROCESS_TIMEOUT_SECONDS=300
TARGET_RATE=16000
AUDIO_CHANNELS=1

# ─── Storage ────────────────────────────────────────────────────────────────
TEMP_DIR=tmp_uploads
DB_PATH=substudy_jobs.db
